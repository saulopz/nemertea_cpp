// Graph name: graphs/pipa.json
// Algorithm : Nemertea
// Run time  : 
// Date      : 
graph G {
	layout=neato;
	overlap=false;
	splines=true;
	bgcolor=OldLace;
	node [pin=true];
	node [shape=circle, width=1.0, height=1.0, fixedsize=true, style=filled, fillcolor="lightblue"];

	V1 [label="", style=filled, pos="30.7,29.3!", fillcolor="blue", color="blue"];
	V2 [label="", style=filled, pos="39.6,29.5!", fillcolor="black", color="black"];
	V3 [label="", style=filled, pos="49.8,23.7!", fillcolor="black", color="black"];
	V4 [label="", style=filled, pos="55,29.4!", fillcolor="black", color="black"];
	V5 [label="", style=filled, pos="48.9,35.2!", fillcolor="black", color="black"];

	V1 -- V2 [color="blue", penwidth=10.0];
	V2 -- V3 [color="black", penwidth=50.0];
	V3 -- V4 [color="black", penwidth=50.0];
	V4 -- V5 [color="black", penwidth=50.0];
	V5 -- V2 [color="black", penwidth=50.0];
}
